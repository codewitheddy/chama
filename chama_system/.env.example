# Copy this to .env for local dev, or set these in Back4App's environment variables

SECRET_KEY=your-very-secret-key-here
DEBUG=False

# Back4App provides a DATABASE_URL — paste it here
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://user:password@host:5432/dbname

# Or set individual DB vars (used if DATABASE_URL is not set)
DB_NAME=chama_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Your Back4App app domain e.g. https://myapp.b4a.run
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://myapp.b4a.run

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Chama System <noreply@chama.local>
